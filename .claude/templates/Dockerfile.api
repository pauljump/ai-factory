# ============================================================
# API Dockerfile Template
# ============================================================
# Usage:
#   1. Copy this file to <project>/api/Dockerfile
#   2. Find-replace __PROJECT__ with your project name
#      (e.g. stuywatch, meter, barkey)
#   3. Build from the monorepo root:
#      docker build -f __PROJECT__/api/Dockerfile .
#
# This template assumes:
#   - Your project lives at __PROJECT__/api/ in the monorepo
#   - It depends on packages/api-kit
#   - It uses pnpm workspaces
#   - SQLite data is stored at /app/data (mount a persistent
#     volume in Cloud Run or docker run -v)
#
# If your project needs native compilation for better-sqlite3
# or other native modules, uncomment the marked lines below
# and switch the base image to node:22-slim.
# ============================================================

FROM node:22-alpine AS builder
WORKDIR /app
RUN corepack enable

# --- Uncomment for native deps (better-sqlite3, etc.) ---
# RUN apk add --no-cache python3 make g++

# Copy workspace files for pnpm
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json tsconfig.base.json ./
COPY packages/api-kit/package.json packages/api-kit/
COPY __PROJECT__/api/package.json __PROJECT__/api/

# Install deps
RUN pnpm install --frozen-lockfile

# Copy source and build
COPY packages/api-kit/ packages/api-kit/
COPY __PROJECT__/api/ __PROJECT__/api/
RUN cd packages/api-kit && pnpm build
RUN cd __PROJECT__/api && pnpm build

# Prune dev dependencies
RUN pnpm prune --prod

FROM node:22-alpine AS runner
WORKDIR /app

# Keep full workspace structure so pnpm symlinks resolve
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/api-kit/node_modules ./packages/api-kit/node_modules
COPY --from=builder /app/packages/api-kit/dist ./packages/api-kit/dist
COPY --from=builder /app/packages/api-kit/package.json ./packages/api-kit/
COPY --from=builder /app/__PROJECT__/api/node_modules ./__PROJECT__/api/node_modules
COPY --from=builder /app/__PROJECT__/api/dist ./__PROJECT__/api/dist
COPY --from=builder /app/__PROJECT__/api/package.json ./__PROJECT__/api/
COPY --from=builder /app/package.json ./

# Data directory for SQLite
RUN mkdir -p /app/data
VOLUME ["/app/data"]

EXPOSE 3000
ENV NODE_ENV=production
WORKDIR /app/__PROJECT__/api
CMD ["node", "dist/index.js"]
